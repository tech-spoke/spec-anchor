ection\",\n        \"docs/spec/auth.md#0004-authorization\"\n      ],\n      \"summary\": \"This chapter defines the system's authentication boundary: users must prove identity before accessing protected areas, and the implementation must treat the session cookie as the primary mechanism after login. It also ties authentication to CSRF protection and role-based authorization, so agents should enter this chapter when a task affects login flow, session handling, unsafe requests, or admin-only access.\"\n    }\n  ],\n  \"generated_at\": \"1970-01-01T00:00:00Z\",\n  \"generation\": {\n    \"failed_chapter_ids\": [],\n    \"failure_reasons_by_chapter\": {},\n    \"metadata_version\": 1,\n    \"model\": \"gpt-5.4-mini\",\n    \"prompt_version\": \"chapter-anchors-v1\",\n    \"provider\": \"codex\",\n    \"stage\": \"chapter_anchors\"\n  },\n  \"schema_version\": 1,\n  \"status\": \"success\"\n}\n","numLines":46,"startLine":1,"totalLines":46}}}
