1T00:00:00Z\",\n          \"possible_conflict\": false,\n          \"reason\": \"Both sections form the server-side request security policy: session cookies carry identity while CSRF tokens protect those cookie-authenticated requests from forgery.\",\n          \"relation_hint\": \"same_policy\",\n          \"target_section_id\": \"docs/spec/auth.md#0003-csrf-protection\"\n        },\n        {\n          \"channels\": [\n            \"search_key_match\"\n          ],\n          \"confidence\": \"medium\",\n          \"evidence_terms\": [\n            \"authentication specification\",\n            \"session\",\n            \"admin role\"\n          ],\n          \"generated_at\": \"1970-01-01T00:00:00Z\",\n          \"possible_conflict\": false,\n          \"reason\": \"Session validity (expiry, logout invalidation) directly affects whether an authorization check can proceed; an expired session must not grant admin access.\",\n          \"relation_hint\": \"impacts\",\n          \"target_section_id\": \"docs/spec/auth.md#0004-authorization\"\n        }\n      ],\n      \"search_keys\": [],\n      \"semantic_hash\": \"a0ceaff86194b771e051919788cb42c930b9c083b2698ac1dd266c0ff75b9410\",\n      \"source_document_id\": \"docs/spec/auth.md\",\n      \"source_hash\": \"433a68ab1268046b860e4ebc95610c013644f085a6de9c330a8ad037c115736b\",\n      \"source_section_id\": \"docs/spec/auth.md#0002-session-management\",\n      \"source_span\": {\n        \"end_line\": 6,\n        \"end_offset\": 156,\n        \"start_line\": 3,\n        \"start_offset\": 54\n      },\n      \"stable_chunk_uid\": \"460e35e7c95721e5\",\n      \"stable_section_uid\": \"460e35e7c95721e5\",\n      \"summary\": \"\",\n      \"text\": \"Authentication Specification / Session Management | HttpOnly\"\n    }\n  },\n  \"warnings\": []\n}\n{\n  \"collection\": \"spec_anchor_section_20260523010512codexe2ef002retest\",\n  \"command\": \"/spec-inject inject-section\",\n  \"found_section_ids\": [\n    \"docs/spec/auth.md#0003-csrf-protection\"\n  ],\n  \"missing_section_ids\": [],\n  \"project_root\": \"/tmp/spec-anchor-codex-e2e-f002-retest.N4Lyjy\",\n  \"requested_section_ids\": [\n    \"docs/spec/auth.md#0003-csrf-protection\"\n  ],\n  \"sections\": {\n    \"docs/spec/auth.md#0003-csrf-protection\": {\n      \"heading_path\": [\n        \"Authentication Specification\",\n        \"CSRF Protection\"\n      ],\n      \"identifiers\": [\n        \"CSRF\",\n        \"POST\",\n        \"PUT\",\n        \"PATCH\",\n        \"DELETE\"\n      ],\n      \"related_sections\": [\n        {\n          \"channels\": [\n            \"search_key_match\"\n          ],\n          \"confidence\": \"high\",\n          \"evidence_terms\": [\n            \"authentication specification\",\n            \"CSRF\",\n            \"403\"\n          ],\n          \"generated_at\": \"1970-01-01T00:00:00Z\",\n          \"possible_conflict\": false,\n          \"reason\": \"CSRF protection is scoped to authenticated state-changing requests; the parent authentication specification establishes the authentication context this section depends on.\",\n          \"relation_hint\": \"prerequisite\",\n          \"target_section_id\": \"docs/spec/auth.md#0001-authentication-specification\"\n        },\n        {\n          \"channels\": [\n            \"search_key_match\"\n          ],\n          \"confidence\": \"high\",\n          \"evidence_terms\": [\n            \"authentication specification\",\n            \"HttpOnly\",\n            \"CSRF token\"\n          ],\n          \"generated_at\": \"1970-01-01T00:00:00Z\",\n          \"possible_conflict\": false,\n          \"reason\": \"CSRF token requirement pairs with the HttpOnly session cookie mechanism; both are complementary server-side defenses applied to the same authenticated requests.\",\n          \"relation_hint\": \"same_policy\",\n          \"target_section_id\": \"docs/spec/auth.md#0002-session-management\"\n        },\n        {\n          \"channels\": [\n            \"search_key_match\"\n          ],\n          \"confidence\": \"medium\",\n          \"evidence_terms\": [\n            \"authentication specification\",\n            \"403\",\n            \"admin role\"\n          ],\n          \"generated_at\": \"1970-01-01T00:00:00Z\",\n          \"possible_conflict\": false,\n          \"reason\": \"Both sections result in 403 responses for disallowed requests (CSRF failure vs. insufficient role); implementors should coordinate the 403 response path.\",\n          \"relation_hint\": \"see_also\",\n          \"target_section_id\": \"docs/spec/auth.md#0004-authorization\"\n        }\n      ],\n      \"search_keys\": [],\n      \"semantic_hash\": \"c1a6a4c9aec98c2168df8ababb237a8a89fec69eece9f46a7a884e24841cdbc5\",\n      \"source_document_id\": \"docs/spec/auth.md\",\n      \"source_hash\": \"02a54aadfea72152048dd1c09d1bf1e94ca9317da00e63d704f71a8252137356\",\n      \"source_section_id\": \"docs/spec/auth.md#0003-csrf-protection\",\n      \"source_span\": {\n        \"end_line\": 10,\n        \"end_offset\": 288,\n        \"start_line\": 7,\n        \"start_offset\": 175\n      },\n      \"stable_chunk_uid\": \"ead5b4571ab9f4d3\",\n      \"stable_section_uid\": \"ead5b4571ab9f4d3\",\n      \"summary\": \"\",\n      \"text\": \"Authentication Specification / CSRF Protection | CSRF POST PUT PATCH DELETE\"\n    }\n  },\n  \"warnings\": []\n}\n{\n  \"collection\": \"spec_anchor_section_20260523010512codexe2ef002retest\",\n  \"command\": \"/spec-inject inject-section\",\n  \"found_section_ids\": [\n    \"docs/spec/auth.md#0004-authorization\"\n  ],\n  \"missing_section_ids\": [],\n  \"project_root\": \"/tmp/spec-anchor-codex-e2e-f002-retest.N4Lyjy\",\n  \"requested_section_ids\": [\n    \"docs/spec/auth.md#0004-authorization\"\n  ],\n  \"sections\": {\n    \"docs/spec/auth.md#0004-authorization\": {\n      \"heading_path\": [\n        \"Authentication Specification\",\n        \"Authorization\"\n      ],\n      \