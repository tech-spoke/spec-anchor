hentication specification\",\n            \"HttpOnly\",\n            \"CSRF token\"\n          ],\n          \"generated_at\": \"1970-01-01T00:00:00Z\",\n          \"possible_conflict\": false,\n          \"reason\": \"CSRF token requirement pairs with the HttpOnly session cookie mechanism; both are complementary server-side defenses applied to the same authenticated requests.\",\n          \"relation_hint\": \"same_policy\",\n          \"target_section_id\": \"docs/spec/auth.md#0002-session-management\"\n        },\n        {\n          \"channels\": [\n            \"search_key_match\"\n          ],\n          \"confidence\": \"medium\",\n          \"evidence_terms\": [\n            \"authentication specification\",\n            \"403\",\n            \"admin role\"\n          ],\n          \"generated_at\": \"1970-01-01T00:00:00Z\",\n          \"possible_conflict\": false,\n          \"reason\": \"Both sections result in 403 responses for disallowed requests (CSRF failure vs. insufficient role); implementors should coordinate the 403 response path.\",\n          \"relation_hint\": \"see_also\",\n          \"target_section_id\": \"docs/spec/auth.md#0004-authorization\"\n        }\n      ],\n      \"search_keys\": [],\n      \"semantic_hash\": \"c1a6a4c9aec98c2168df8ababb237a8a89fec69eece9f46a7a884e24841cdbc5\",\n      \"source_document_id\": \"docs/spec/auth.md\",\n      \"source_hash\": \"02a54aadfea72152048dd1c09d1bf1e94ca9317da00e63d704f71a8252137356\",\n      \"source_section_id\": \"docs/spec/auth.md#0003-csrf-protection\",\n      \"source_span\": {\n        \"end_line\": 10,\n        \"end_offset\": 288,\n        \"start_line\": 7,\n        \"start_offset\": 175\n      },\n      \"stable_chunk_uid\": \"ead5b4571ab9f4d3\",\n      \"stable_section_uid\": \"ead5b4571ab9f4d3\",\n      \"summary\": \"\",\n      \"text\": \"Authentication Specification / CSRF Protection | CSRF POST PUT PATCH DELETE\"\n    }\n  },\n  \"warnings\": []\n}\n{\n  \"collection\": \"spec_a