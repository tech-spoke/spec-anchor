ntication.\",\n          \"relation_hint\": \"depends_on\",\n          \"target_section_id\": \"docs/spec/auth.md#0003-csrf-protection\"\n        },\n        {\n          \"channels\": [\n            \"search_key_match\"\n          ],\n          \"confidence\": \"high\",\n          \"evidence_terms\": [\n            \"authentication specification\",\n            \"admin role\",\n            \"403\"\n          ],\n          \"generated_at\": \"1970-01-01T00:00:00Z\",\n          \"possible_conflict\": false,\n          \"reason\": \"Authentication specification is the parent section; authorization is a direct child that governs what authenticated users are permitted to do based on role.\",\n          \"relation_hint\": \"depends_on\",\n          \"target_section_id\": \"docs/spec/auth.md#0004-authorization\"\n        }\n      ],\n      \"search_keys\": [],\n      \"semantic_hash\": \"e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855\",\n      \"source_document_id\": \"docs/spec/auth.md\",\n      \"source_hash\": \"01ba4719c80b6fe911b091a7c05124b64eeece964e09c058ef8f9805daca546b\",\n      \"source_section_id\": \"docs/spec/auth.md#0001-authentication-specification\",\n      \"source_span\": {\n        \"end_line\": 2,\n        \"end_offset\": 32,\n        \"start_line\": 1,\n        \"start_offset\": 31\n      },\n      \"stable_chunk_uid\": \"9e6a7527ae5c348d\",\n      \"stable_section_uid\": \"9e6a7527ae5c348d\",\n      \"summary\": \"\",\n      \"text\": \"Authentication Specification\"\n    }\n  },\n  \"warnings\": []\n}\n{\n  \"collection\": \"spec_anchor_section_20260523010512codexe2ef002retest\",\n  \"command\": \"/spec-inject inject-section\",\n  \"found_section_ids\": [\n    \"docs/spec/auth.md#0002-session-management\"\n  ],\n  \"missing_section_ids\": [],\n  \"project_root\": \"/tmp/spec-anchor-codex-e2e-f002-retest.N4Lyjy\",\n  \"requested_section_ids\": [\n    \"docs/spec/auth.md#0002-session-management\"\n  ],\n  \"sections\": {\n    \"docs