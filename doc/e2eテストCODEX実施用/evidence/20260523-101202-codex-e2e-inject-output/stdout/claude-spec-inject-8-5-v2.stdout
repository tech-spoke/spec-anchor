t-required` および `docs/spec/audit.md#0002-audit-storage-boundary` の両方で「法務確認待ち・未確定」と明記されている。実装時に日数をハードコード・推測・デフォルト設定してはならない。確定値は人間（法務確認後）が提供すること。","stop_reason":"end_turn","session_id":"f81501bd-1f3c-4bf0-b882-f5478c276b60","total_cost_usd":0.20909250000000001,"usage":{"input_tokens":6,"cache_creation_input_tokens":27516,"cache_read_input_tokens":111965,"output_tokens":4820,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":27516,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[{"input_tokens":1,"output_tokens":3517,"cache_read_input_tokens":40003,"cache_creation_input_tokens":983,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":983},"type":"message"}],"speed":"standard"},"modelUsage":{"claude-sonnet-4-6":{"inputTokens":6,"outputTokens":4820,"cacheReadInputTokens":111965,"cacheCreationInputTokens":27516,"webSearchRequests":0,"costUSD":0.20909250000000001,"contextWindow":400000,"maxOutputTokens":32000}},"permission_denials":[],"terminal_reason":"completed","fast_mode_state":"off","uuid":"99665ba8-997a-469b-b1f8-b197468b7340"}
