持**\nパスワード認証直後に MFA チャレンジ → 成功後にのみセッション発行 → 失敗時は監査イベントだけ残す、という現行仕様のフローを変更しない。","stop_reason":"end_turn","session_id":"e243e034-2d52-447e-b528-d20c149f6c59","total_cost_usd":0.27971535,"usage":{"input_tokens":8,"cache_creation_input_tokens":34229,"cache_read_input_tokens":181742,"output_tokens":6454,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":34229,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[{"input_tokens":1,"output_tokens":1291,"cache_read_input_tokens":39693,"cache_creation_input_tokens":8006,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":8006},"type":"message"}],"speed":"standard"},"modelUsage":{"claude-sonnet-4-6":{"inputTokens":8,"outputTokens":6454,"cacheReadInputTokens":181742,"cacheCreationInputTokens":34229,"webSearchRequests":0,"costUSD":0.27971535,"contextWindow":400000,"maxOutputTokens":32000}},"permission_denials":[],"terminal_reason":"completed","fast_mode_state":"off","uuid":"48c85ce9-b2bc-4f26-b80c-8a7a58e1f57f"}
