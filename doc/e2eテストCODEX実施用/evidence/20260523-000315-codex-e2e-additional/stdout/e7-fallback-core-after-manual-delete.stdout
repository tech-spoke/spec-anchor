          "source_section_id": "docs/spec/sample.md#0003-authorization",
          "stable_section_uid": "789420154d18ed9f",
          "summary": "Administrators can read, create, update, and delete any resource, while regular users can only read and update resources they own; service accounts use API keys instead of the login screen."
        },
