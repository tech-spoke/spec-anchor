         \"confidence\": \"high\",\n          \"evidence_terms\": [\n            \"authentication specification\",\n            \"CSRF\",\n            \"403\"\n          ],\n          \"generated_at\": \"1970-01-01T00:00:00Z\",\n          \"possible_conflict\": false,\n          \"reason\": \"CSRF protection is scoped to authenticated state-changing requests; the parent authentication specification establishes the authentication context this section depends on.\",\n          \"relation_hint\": \"prerequisite\",\n          \"target_section_id\": \"docs/spec/auth.md#0001-authentication-specification\"\n        },\n        {\n          \"channels\": [\n            \"search_key_match\"\n          ],\n          \"confidence\": \"high\",\n          \"evidence_terms\": [\n            \"authentication specification\",\n            \"HttpOnly\",\n            \"CSRF token\"\n          ],\n          \"generated_at\": \"1970-01-01T00:00:00Z\",\n          \"possible_conflict\": false,\n          \"reason\": \"CSRF token requirement pairs with the HttpOnly session cookie mechanism; both are complementary server-side defenses applied to the same authenticated requests.\",\n          \"relation_hint\": \"same_policy\",\n          \"target_section_id\": \"docs/spec/auth.md#0002-session-management\"\n        },\n        {\n          \"channels\": [\n            \"search_key_match\"\n          ],\n          \"confidence\": \"medium\",\n          \"evidence_terms\": [\n            \"authentication specification\",\n            \"403\",\n            \"admin role\"\n          ],\n          \"generated_at\": \"1970-01-01T00:00:00Z\",\n          \"possible_conflict\": false,\n          \"reason\": \"Both sections result in 403 responses for disallowed requests (CSRF failure vs. insufficient role); implementors should coordinate the 403 response path.\",\n          \"relation_hint\": \"see_also\",\n          \"target_section_id\": \"docs/spec/auth.md#0004-authorization\"\n        }\n      ]