"possible_conflict\": false,\n          \"reason\": \"CSRF token requirement pairs with the HttpOnly session cookie mechanism; both are complementary server-side defenses applied to the same authenticated requests.\",\n          \"relation_hint\": \"same_policy\",\n          \"target_section_id\": \"docs/spec/auth.md#0002-session-management\"\n        },\n        {\n          \"channels\": [\n            \"search_key_match\"\n          ],\n          \"confidence\": \"medium\",\n          \"evidence_terms\": [\n            \"authentication specification\",\n            \"403\",\n            \"admin role\"\n          ],\n          \"generated_at\": \"1970-01-01T00:00:00Z\",\n          \"possible_conflict\": false,\n          \"reason\": \"Both sections result in 403 responses for disallowed requests (CSRF failure vs. insufficient role); implementors should coordinate the 403 response path.\",\n          \"relation_hint\": \"see_also\",\n          \"target_section_id\": \"docs/spec/auth.md#0004-authorization\"\n        }\n      ],\n      \"score\": 0.03278688524590164,\n      \"search_keys\": [\n        \"csrf protection\",\n        \"cross site request forgery\",\n        \"state changing requests\",\n        \"forbidden without token\",\n        \"request token validation\",\n        \"write action protection\",\n        \"unsafe method defense\",\n        \"Authentication Specification\",\n        \"CSRF Protection\"\n      ],\n      \"source_document_id\": \"docs/spec/auth.md\",\n      \"source_section_id\": \"docs/spec/auth.md#0003-csrf-protection\",\n      \"source_span\": {\n        \"end_line\": 10,\n        \"end_offset\": 288,\n        \"start_line\": 7,\n        \"start_offset\": 175\n      },\n      \"summary\": \"Requires protection against cross-site request forgery for state-changing requests and rejects requests missing a valid token with a forbidden response.\"\n    },\n    {\n      \"heading_path\": [\n        \"Authentication Specification\",\n      