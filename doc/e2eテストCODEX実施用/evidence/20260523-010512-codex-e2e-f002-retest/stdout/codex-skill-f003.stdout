      ],\\n          \\\"generated_at\\\": \\\"1970-01-01T00:00:00Z\\\",\\n          \\\"possible_conflict\\\": false,\\n          \\\"reason\\\": \\\"Authentication specification is the parent section; CSRF protection is a direct child that enforces token validation on state-changing requests post-authentication.\\\",\\n          \\\"relation_hint\\\": \\\"depends_on\\\",\\n          \\\"target_section_id\\\": \\\"docs/spec/auth.md#0003-csrf-protection\\\"\\n        },\\n        {\\n          \\\"channels\\\": [\\n            \\\"search_key_match\\\"\\n          ],\\n          \\\"confidence\\\": \\\"high\\\",\\n          \\\"evidence_terms\\\": [\\n            \\\"authentication specification\\\",\\n            \\\"admin role\\\",\\n            \\\"403\\\"\\n          ],\\n          \\\"generated_at\\\": \\\"1970-01-01T00:00:00Z\\\",\\n          \\\"possible_conflict\\\": false,\\n          \\\"reason\\\": \\\"Authentication specification is the parent section; authorization is a direct child that governs what authenticated users are permitted to do based on role.\\\",\\n          \\\"relation_hint\\\": \\\"depends_on\\\",\\n          \\\"target_section_id\\\": \\\"docs/spec/auth.md#0004-authorization\\\"\\n        }\\n      ],\\n      \\\"search_keys\\\": [\\n        \\\"authentication requirements\\\",\\n        \\\"login and sign in\\\",\\n        \\\"user identity verification\\\",\\n        \\\"access to protected areas\\\",\\n        \\\"credential validation\\\",\\n        \\\"Authentication Specification\\\"\\n      ],\\n      \\\"semantic_hash\\\": \\\"e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855\\\",\\n      \\\"source_document_id\\\": \\\"docs/spec/auth.md\\\",\\n      \\\"source_hash\\\": \\\"01ba4719c80b6fe911b091a7c05124b64eeece964e09c058ef8f9805daca546b\\\",\\n      \\\"source_section_id\\\": \\\"docs/spec/auth.md#0001-authentication-specification\\\",\\n      \\\"source_span\\\": {\\n        \\\"end_line\\\": 2,\\n        \\\"end_offset\\\": 32,\\n        \\\"start_line\\\": 1,\\n        \\\"start_offset\\\": 31\\n      },\\n      \\\"stable_chunk_uid\\\": \\\"9e6a7527ae5c348d\\\",\\n      \\\"stable_section_uid\\\": \\\"9e6a7527ae5c348d\\\",\\n      \\\"summary\\\": \\\"Top-level authentication requirements for the system, covering how users prove identity before gaining access.\\\",\\n      \\\"text\\\": \\\"Authentication Specification | Top-level authentication requirements for the system, covering how users prove identity before gaining access. | authentication requirements login and sign in user identity verification access to protected areas credential validation Authentication Specification\\\"\\n    },\\n    \\\"docs/spec/auth.md#0002-session-management\\\": {\\n      \\\"heading_path\\\": [\\n        \\\"Authentication Specification\\\",\\n        \\\"Session Management\\\"\\n      ],\\n      \\\"identifiers\\\": [\\n        \\\"HttpOnly\\\"\\n      ],\\n      \\\"related_sections\\\": [\\n        {\\n          \\\"channels\\\": [\\n            \\\"search_key_match\\\"\\n          ],\\n          \\\"confidence\\\": \\\"high\\\",\\n          \\\"evidence_terms\\\": [\\n            \\\"authentication specification\\\",\\n            \\\"HttpOnly\\\",\\n            \\\"CSRF\\\"\\n          ],\\n          \\\"generated_at\\\": \\\"1970-01-01T00:00:00Z\\\",\\n          \\\"possible_conflict\\\": false,\\n          \\\"reason\\\": \\\"Both sections form the server-side request security policy: session cookies carry identity while CSRF tokens protect those cookie-authenticated requests from forgery.\\\",\\n          \\\"relation_hint\\\": \\\"same_policy\\\",\\n          \\\"target_section_id\\\": \\\"docs/spec/auth.md#0003-csrf-protection\\\"\\n        },\\n        {\\n          \\\"channels\\\": [\\n            \\\"search_key_match\\\"\\n          ],\\n          \\\"confidence\\\": \\\"medium\\\",\\n          \\\"evidence_terms\\\": [\\n            \\\"authentication specification\\\",\\n            \\\"session\\\",\\n            \\\"admin role\\\"\\n          ],\\n          \\\"generated_at\\\": \\\"1970-01-01T00:00:00Z\\\",\\n          \\\"possible_conflict\\\": false,\\n          \\\"reason\\\": \\\"Session validity (expiry, logout invalidation) directly affects whether an authorization check can proceed; an expired session must not grant admin access.\\\",\\n          \\\"relation_hint\\\": \\\"impacts\\\",\\n          \\\"target_section_id\\\": \\\"docs/spec/auth.md#0004-authorization\\\"\\n        }\\n      ],\\n      \\\"search_keys\\\": [\\n        \\\"session management\\\",\\n        \\\"secure login cookie\\\",\\n        \\\"cookie marked http only\\\",\\n        \\\"cookie marked secure\\\",\\n        \\\"session expiration\\\",\\n        \\\"logout invalidates session\\\",\\n        \\\"login session timeout\\\",\\n        \\\"Authentication Specification\\\",\\n        \\\"Session Management\\\"\\n      ],\\n      \\\"semantic_hash\\\": \\\"a0ceaff86194b771e051919788cb42c930b9c083b2698ac1dd266c0ff75b9410\\\",\\n      \\\"source_document_id\\\": \\\"docs/spec/auth.md\\\",\\n      \\\"source_hash\\\": \\\"433a68ab1268046b860e4ebc95610c013644f085a6de9c330a8ad037c115736b\\\",\\n      \\\"source_section_id\\\": \\\"docs/spec/auth.md#0002-session-management\\\",\\n      \\\"source_span\\\": {\\n        \\\"end_line\\\": 6,\\n        \\\"end_offset\\\": 156,\\n        \\\"start_line\\\": 3,\\n        \\\"start_offset\\\": 54\\n      },\\n      \\\"stable_chunk_uid\\\": \\\"460e35e7c95721e5\\\",\\n      \\\"stable_section_uid\\\": \\\"460e35e7c95721e5\\\",\\n      \\\"summary\\\": \\\"Describes session cookie handling after login, including secure cookie flags, default timeout, and immediate invalidation on logout.\\\",\\n      \\\"text\\\": \\\"Authentication Specification / Session Management | Describes session cookie handling after login, including secure cookie flags, default timeout, and immediate invalidation on logout. | session management secure login cookie cookie marked http only cookie marked secure session expiration logout invalidates session login session timeout Authentication Specification | HttpOnly\\\"\\n    },\\n    \\\"docs/spec/auth.md#0003-csrf-protection\\\": {\\n      \\\"heading_path\\\": [\\n        \\\"Authentication Specification\\\",\\n        \\\"CSRF Protection\\\"\\n      ],\\n      \\\"identifiers\\\": [\\n        \\\"CSRF\\\",\\n        \\\"POST\\\",\\n        \\\"PUT\\\",\\n        \\\"PATCH\\\",\\n        \\\"DELETE\\\"\\n      ],\\n      \\\"related_sections\\\": [\\n        {\\n          \\\"channels\\\": [\\n            \\\"search_key_match\\\"\\n          ],\\n          \\\"confidence\\\": \\\"high\\\",\\n          \\\"evidence_terms\\\": [\\n            \\\"authentication specification\\\",\\n            \\\"CSRF\\\",\\n            \\\"403\\\"\\n          ],\\n          \\\"generated_at\\\": \\\"1970-01-01T00:00:00Z\\\",\\n          \\\"possible_conflict\\\": false,\\n          \\\"reason\\\": \\\"CSRF protection is scoped to authenticated state-changing requests; the parent authentication specification establishes the authentication context this section depends on.\\\",\\n          \\\"relation_hint\\\": \\\"prerequisite\\\",\\n          \\\"target_section_id\\\": \\\"docs/spec/auth.md#0001-authentication-specification\\\"\\n        },\\n        {\\n          \\\"channels\\\": [\\n            \\\"search_key_match\\\"\\n          ],\\n          \\\"confidence\\\": \\\"high\\\",\\n          \\\"evidence_terms\\\": [\\n            \\\"authentication specification\\\",\\n            \\\"HttpOnly\\\",\\n            \\\"CSRF token\\\"\\n          ],\\n          \\\"generated_at\\\": \\\"1970-01-01T00:00:00Z\\\",\\n          \\\"possible_conflict\\\": false,\\n          \\\"reason\\\": \\\"CSRF token requirement pairs with the HttpOnly session cookie mechanism; both are complementary server-side defenses applied to the same authenticated requests.\\\",\\n          \\\"relation_hint\\\": \\\"same_policy\\\",\\n          \\\"target_section_id\\\": \\\"docs/spec/auth.md#0002-session-management\\\"\\n        },\\n        {\\n          \\\"channels\\\": [\\n            \\\"search_key_match\\\"\\n          ],\\n          \\\"confidence\\\": \\\"medium\\\",\\n          \\\"evidence_terms\\\": [\\n            \\\"authentication specification\\\",\\n            \\\"403\\\",\\n            \\\"admin role\\\"\\n          ],\\n          \\\"generated_at\\\": \\\"1970-01-01T00:00:00Z\\\",\\n          \\\"possible_conflict\\\": false,\\n          \\\"reason\\\": \\\"Both sections result in 403 responses for disallowed requests (CSRF failure vs. insufficient role); implementors should coordinate the 403 response path.\\\",\\n          \\\"relation_hint\\\": \\\"see_also\\\",\\n          \\\"target_section_id\\\": \\\"docs/spec/auth.md#0004-authorization\\\"\\n        }\\n      ],\\n      \\\"search_keys\\\": [\\n        \\\"csrf protection\\\",\\n        \\\"cross site request forgery\\\",\\n        \\\"state changing requests\\\",\\n        \\\"forbidden without token\\\",\\n        \\\"request token validation\\\",\\n        \\\"write action protection\\\",\\n        \\\"unsafe method defense\\\",\\n        \\\"Authentication Specification\\\",\\n        \\\"CSRF Protection\\\"\\n      ],\\n      \\\"semantic_hash\\\": \\\"c1a6a4c9aec98c2168df8ababb237a8a89fec69eece9f46a7a884e24841cdbc5\\\",\\n      \\\"source_document_id\\\": \\\"docs/spec/auth.md\\\",\\n      \\\"source_hash\\\": \\\"02a54aadfea72152048dd1c09d1bf1e94ca9317da00e63d704f71a8252137356\\\",\\n      \\\"source_section_id\\\": \\\"docs/spec/auth.md#0003-csrf-protection\\\",\\n      \\\"source_span\\\": {\\n        \\\"end_line\\\": 10,\\n        \\\"end_offset\\\": 288,\\n        \\\"start_line\\\": 7,\\n        \\\"start_offset\\\": 175\\n      },\\n      \\\"stable_chunk_uid\\\": \\\"ead5b4571ab9f4d3\\\",\\n      \\\"stable_section_uid\\\": \\\"ead5b4571ab9f4d3\\\",\\n      \\\"summary\\\": \\\"Requires protection against cross-site request forgery for state-changing requests and rejects requests missing a valid token with a forbidden response.\\\",\\n      \\\"text\\\": \\\"Authentication Specification / CSRF Protection | Requires protection against cross-site request forgery for state-changing requests and rejects requests missing a valid token with a forbidden response. | csrf protection cross site request forgery state changing requests forbidden without token request token validation write action protection unsafe method defense Authentication Specification | CSRF POST PUT PATCH DELETE\\\"\\n    },\\n    \\\"docs/spec/auth.md#0004-authorization\\\": {\\n      \\\"heading_path\\\": [\\n        \\\"Authentication Specification\\\",\\n        \\\"Authorization\\\"\\n      ],\\n      \\\"identifiers\\\": [],\\n      \\\"related_sections\\\": [\\n        {\\n          \\\"channels\\\": [\\n            \\\"search_key_match\\\"\\n          ],\\n          \\\"confidence\\\": \\\"high\\\",\\n          \\\"evidence_terms\\\": [\\n            \\\"authentication specification\\\",\\n            \\\"admin role\\\",\\n            \\\"認証済み\\\"\\n          ],\\n          \\\"generated_at\\\": \\\"1970-01-01T00:00:00Z\\\",\\n          \\\"possible_conflict\\\": false,\\n          \\\"reason\\\": \\\"Authorization rules apply only to already-authenticated users; the parent authentication specification is a prerequisite for the role check described here.\\\",\\n          \\\"relation_hint\\\": \\\"prerequisite\\\",\\n          \\\"target_section_id\\\": \\\"docs/spec/auth.md#0001-authentication-specification\\\"\\n        },\\n        {\\n          \\\"channels\\\": [\\n            \\\"search_key_match\\\"\\n          ],\\n          \\\"confidence\\\": \\\"medium\\\",\\n          \\\"evidence_terms\\\": [\\n            \\\"authentication specification\\\",\\n            \\\"session\\\",\\n            \\\"admin role\\\"\\n          ],\\n          \\\"generated_at\\\": \\\"1970-01-01T00:00:00Z\\\",\\n          \\\"possible_conflict\\\": false,\\n          \\\"reason\\\": \\\"Authorization checks rely on a valid session to identify the user's role; session expiry or logout must propagate to revoke admin access.\\\",\\n          \\\"relation_hint\\\": \\\"depends_on\\\",\\n          \\\"target_section_id\\\": \\\"docs/spec/auth.md#0002-session-management\\\"\\n        },\\n        {\\n          \\\"channels\\\": [\\n            \\\"search_key_match\\\"\\n          ],\\n          \\\"confidence\\\": \\\"medium\\\",\\n          \\\"evidence_terms\\\": [\\n            \\\"authentication specification\\\",\\n            \\\"CSRF\\\",\\n            \\\"403\\\"\\n          ],\\n          \\\"generated_at\\\": \\\"1970-01-01T00:00:00Z\\\",\\n          \\\"possible_conflict\\\": false,\\n          \\\"reason\\\": \\\"Admin operations that mutate state are subject to both CSRF validation and role authorization; both must pass for the request to succeed.\\\",\\n          \\\"relation_hint\\\": \\\"see_also\\\",\\n          \\\"target_section_id\\\": \\\"docs/spec/auth.md#0003-csrf-protection\\\"\\n        }\\n      ],\\n      \\\"search_keys\\\": [\\n        \\\"authorization rules\\\",\\n        \\\"admin only access\\\",\\n        \\\"role based permissions\\\",\\n        \\\"administrative actions\\\",\\n        \\\"forbidden for non admins\\\",\\n        \\\"privileged operations\\\",\\n        \\\"access control by role\\\",\\n        \\\"Authentication Specification\\\",\\n        \\\"Authorization\\\"\\n      ],\\n      \\\"semantic_hash\\\": \\\"a0089f4027f1a49861681466e1b736e38d0386058dbd26e4ddfb4e2c2ba1feba\\\",\\n      \\\"source_document_id\\\": \\\"docs/spec/auth.md\\\",\\n      \\\"source_hash\\\": \\\"a627ccd4110068745b72037e8c3fd80faa1850088c2bb7ba4ab746c85c33269b\\\",\\n      \\\"source_section_id\\\": \\\"docs/spec/auth.md#0004-authorization\\\",\\n      \\\"source_span\\\": {\\n        \\\"end_line\\\": 13