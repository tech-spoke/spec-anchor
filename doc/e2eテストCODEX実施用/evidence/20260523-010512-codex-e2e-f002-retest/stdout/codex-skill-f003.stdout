int\\\": \\\"same_policy\\\",\\n          \\\"target_section_id\\\": \\\"docs/spec/auth.md#0003-csrf-protection\\\"\\n        },\\n        {\\n          \\\"channels\\\": [\\n            \\\"search_key_match\\\"\\n          ],\\n          \\\"confidence\\\": \\\"medium\\\",\\n          \\\"evidence_terms\\\": [\\n            \\\"authentication specification\\\",\\n            \\\"session\\\",\\n            \\\"admin role\\\"\\n          ],\\n          \\\"generated_at\\\": \\\"1970-01-01T00:00:00Z\\\",\\n          \\\"possible_conflict\\\": false,\\n          \\\"reason\\\": \\\"Session validity (expiry, logout invalidation) directly affects whether an authorization check can proceed; an expired session must not grant admin access.\\\",\\n          \\\"relation_hint\\\": \\\"impacts\\\",\\n          \\\"target_section_id\\\": \\\"docs/spec/auth.md#0004-authorization\\\"\\n        }\\n      ],\\n      \\\"score\\\": 0.03252247488101534,\\n      \\\"search_keys\\\": [\\n        \\\"session management\\\",\\n        \\\"secure login cookie\\\",\\n        \\\"cookie marked http only\\\",\\n        \\\"cookie marked secure\\\",\\n        \\\"session expiration\\\",\\n        \\\"logout invalidates session\\\",\\n        \\\"login session timeout\\\",\\n        \\\"Authentication Specification\\\",\\n        \\\"Session Management\\\"\\n      ],\\n      \\\"source_document_id\\\": \\\"docs/spec/auth.md\\\",\\n      \\\"source_section_id\\\": \\\"docs/spec/auth.md#0002-session-management\\\",\\n      \\\"source_span\\\": {\\n        \\\"end_line\\\": 6,\\n        \\\"end_offset\\\": 156,\\n        \\\"start_line\\\": 3,\\n        \\\"start_offset\\\": 54\\n      },\\n      \\\"summary\\\": \\\"Describes session cookie handling after login, including secure cookie flags, default timeout, and immediate invalidation on logout.\\\"\\n    },\\n    {\\n      \\\"heading_path\\\": [\\n        \\\"Authentication Specification\\\",\\n        \\\"CSRF Protection\\\"\\n      ],\\n   