\": {\n    \"failed_chapter_ids\": [],\n    \"failure_reasons_by_chapter\": {},\n    \"metadata_version\": 1,\n    \"model\": \"gpt-5.4-mini\",\n    \"prompt_version\": \"chapter-anchors-v1\",\n    \"provider\": \"codex\",\n    \"stage\": \"chapter_anchors\"\n  },\n  \"schema_version\": 1,\n  \"status\": \"success\"\n}\n","exit_code":0,"status":"completed"}}
