{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NaLDU9Wvw2M3SD8ZAcAtJA","type":"tool_result","content":"usage: spec-anchor [-h] [--version] command ...\n\nLightweight SPEC-anchor CLI.\n\npositional arguments:\n  command\n    core            update section metadata, retrieval index, and conflict\n                    review items\n    inject-search   Phase R-6: section-level Qdrant hybrid retrieval (top-K\n                    section payload)\n    inject-section  Phase R-6: id-indexed section payload lookup against\n                    Qdrant\n    inject-chapters\n                    Phase R-6: return chapter_anchors.json for the project\n    inject-purpose  Phase R-6: return Purpose + Core Concept file contents\n    inject-conflicts\n                    Phase R-6: return resolved (non-stale) Conflict Review\n                    Items\n    realign         structure the Agent-supplied answer into the RealignResult\n                    layout\n    watch           watch Source Specs and run incremental updates\n\noptions:\n  -h, --help        show this help message and exit\n  --version         show program's version number and exit","is_error":false}]},"parent_tool_use_id":null,"session_id":"c5976bea-db53-4952-a093-280a919f4f68","uuid":"0553f554-ecff-410f-9782-51955b49bcd3","timestamp":"2026-05-22T15:35:00.439Z","tool_use_result":{"stdout":"usage: spec-anchor [-h] [--version] command ...\n\nLightweight SPEC-anchor CLI.\n\npositional arguments:\n  command\n    core            update section metadata, retrieval index, and conflict\n                    review items\n    inject-search   Phase R-6: section-level Qdrant hybrid retrieval (top-K\n                    section payload)\n    inject-section  Phase R-6: id-indexed section payload lookup against\n                    Qdrant\n    inject-chapters\n                    Phase R-6: return chapter_anchors.json for the project\n    inject-purpose  Phase R-6: return Purpose + Core Concept file contents\n    inject-conflicts\n                    Phase R-6: return resolved (non-stale) Conflict Review\n                    Items\n    realign         structure the Agent-supplied answer into the RealignResult\n                    layout\n    watch           watch Source Specs and run incremental updates\n\noptions:\n  -h, --help        show this help message and exit\n  --version         show program's version number and exit","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
