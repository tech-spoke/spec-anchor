      "conflict_id": "section_pair:sha256:v1:6b8d7987c31ccfaed3489b0bc6a9bda1449ac407fbab771d320f8692fcfcd02d",
      "conflict_points": [
        {
          "left_excerpt": "A successful login establishes a session that expires after 48 hours of inactivity.",
          "right_excerpt": "Sessions that exceed the 24-hour inactivity window are automatically purged by a background sweep that runs every five minutes.",
          "severity": "high",
          "why_conflicting": "Authentication states sessions expire after 48 hours of inactivity; Session Termination states sessions are purged after 24 hours of inactivity. The two sections specify different numeric thresholds for the same inactivity-expiry rule, making the effective timeout undefined."
        }
      ],
      "created_at": "1970-01-01T00:00:00Z",
      "recommended_next_action": "A human author must decide the canonical inactivity timeout value and update one of the two sections to match. Once reconciled, the section hashes will change and this pair should be re-evaluated.",
      "related_sections": [],
