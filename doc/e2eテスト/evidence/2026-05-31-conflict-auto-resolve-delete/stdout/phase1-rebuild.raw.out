      "conflict_id": "section_pair:sha256:v1:43bcd5b08da14fdac838298a88ae0fbb3bce313831d935a9a79c90376df8420f",
      "conflict_points": [
        {
          "left_excerpt": "A successful login establishes a session that expires after 24 hours of inactivity.",
          "right_excerpt": "all session records must be retained and kept active for a minimum of 30 days regardless of inactivity. Sessions must not be terminated before the 30-day retention window has elapsed.",
          "severity": "high",
          "why_conflicting": "24-hour inactivity expiry directly contradicts the 30-day minimum retention with prohibition on early termination."
        }
      ],
      "created_at": "1970-01-01T00:00:00Z",
      "recommended_next_action": "Human owner must clarify whether Session Retention Policy refers to audit log records (compatible with 24h expiry) or to live authenticated sessions (incompatible). If the former, reword Session Retention Policy to use 'session records' explicitly distinct from 'active sessions'. If the latter, resolve the numeric contradiction between 24 hours and 30 days.",
      "related_sections": [],
      "section_pair": {
        "candidate_origin": "all_pairs",
        "left_section_id": "docs/spec/sample.md#0002-authentication",
        "right_section_id": "docs/spec/sample.md#0005-session-retention-policy",
