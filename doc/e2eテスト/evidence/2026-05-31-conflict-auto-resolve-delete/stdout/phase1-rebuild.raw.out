        },
        {
          "hash": "b5c8c7e3e58676afe4837cb64a7715467f7f3d4cbd098a5c0f4cb7f8b499d3e5",
          "source_ref": "docs/core/concept.md"
        }
      ],
      "conflict_id": "section_pair:sha256:v1:ba084ef7f58f8bf00bff1cb69a629e48c021314cc02083af4f83ffb3ad463152",
      "conflict_points": [
        {
          "left_excerpt": "Sessions that exceed the 24-hour inactivity window are automatically purged by a background sweep that runs every five minutes.",
          "right_excerpt": "all session records must be retained and kept active for a minimum of 30 days regardless of inactivity. Sessions must not be terminated before the 30-day retention window has elapsed.",
          "severity": "high",
          "why_conflicting": "Section A purges inactive sessions after 24 hours; Section B prohibits terminating any session before 30 days have elapsed regardless of inactivity. A session inactive for 25 hours would be purged by A but must survive under B."
        }
      ],
      "created_at": "1970-01-01T00:00:00Z",
      "recommended_next_action": "Human owner should clarify whether 'session records' in the retention policy refers to live session tokens or audit-log entries. If they are distinct concepts, rewrite each section to make the distinction explicit. If they refer to the same object, one policy must be amended.",
      "related_sections": [],
      "section_pair": {
        "candidate_origin": "all_pairs",
        "left_section_id": "docs/spec/sample.md#0004-session-termination",
        "right_section_id": "docs/spec/sample.md#0005-session-retention-policy",
