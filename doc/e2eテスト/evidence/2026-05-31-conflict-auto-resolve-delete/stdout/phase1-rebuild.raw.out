            "Account Lockout"
          ],
          "source_document_id": "docs/spec/sample.md",
          "source_hash": "1a3addf414634968c32e361e576a8ad06a84c0ef1a7a1170d35e9b22f8bf4756",
          "source_ref": "docs/spec/sample.md#0006-account-lockout",
