      "conflict_points": [
        {
          "left_excerpt": "A successful login establishes a session that expires after 48 hours of inactivity.",
          "right_excerpt": "all session records must be retained and kept active for a minimum of 30 days regardless of inactivity. Sessions must not be terminated before the 30-day retention window has elapsed.",
          "severity": "high",
          "why_conflicting": "48-hour inactivity expiry directly contradicts the 30-day minimum retention requirement. A session inactive for 49 hours would be expired under Authentication rules but prohibited from termination under Session Retention Policy."
        }
      ],
      "created_at": "1970-01-01T00:00:00Z",
      "recommended_next_action": "Clarify whether 'session record' in the retention policy refers to an audit log entry (separate from the live session token) or the active session itself. If they are the same object, one of the two timeout values must be changed or a reconciliation rule (e.g., 'token expires but record is retained') must be added.",
      "related_sections": [],
