          "source_ref": "docs/core/concept.md"
        }
      ],
      "conflict_id": "section_pair:sha256:v1:ba084ef7f58f8bf00bff1cb69a629e48c021314cc02083af4f83ffb3ad463152",
      "conflict_points": [
        {
          "left_excerpt": "Sessions that exceed the 24-hour inactivity window are automatically purged by a background sweep that runs every five minutes.",
          "right_excerpt": "all session records must be retained and kept active for a minimum of 30 days regardless of inactivity. Sessions must not be terminated before the 30-day retention window has elapsed.",
          "severity": "high",
          "why_conflicting": "The 24-hour inactivity purge directly violates the 30-day minimum retention requirement; a session inactive for 25 hours would be purged under Section A but must remain active under Section B."
        }
      ],
      "created_at": "1970-01-01T00:00:00Z",
      "recommended_next_action": "Human author must decide: (1) does the 30-day retention override the 24-hour inactivity purge entirely, (2) is the purge limited to in-memory/active session state while audit records are retained separately, or (3) is one of the two rules incorrect and should be removed or scoped.",
      "related_sections": [],
      "section_pair": {
