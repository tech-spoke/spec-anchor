          "source_ref": "docs/spec/sample.md#0006-account-lockout"
        },
        {
          "hash": "990acca6acc83466e32ea730efba95ff4f5cadddb716751355ba26615a18f48b",
          "source_ref": "docs/core/purpose.md"
