      "conflict_points": [
        {
          "left_excerpt": "A successful login establishes a session that expires after 48 hours of inactivity.",
          "right_excerpt": "Sessions that exceed the 24-hour inactivity window are automatically purged by a background sweep that runs every ten minutes.",
          "severity": "high",
          "why_conflicting": "Authentication states the inactivity timeout is 48 hours; Session Termination states the inactivity window is 24 hours. These are contradictory values for the same observable behaviour (when an idle session is invalidated)."
        }
      ],
      "created_at": "1970-01-01T00:00:00Z",
      "recommended_next_action": "The human specification owner should open docs/spec/sample.md and align the inactivity timeout to a single value in both the Authentication section (line 6) and the Session Termination section (line 14), then re-run /spec-core --all to regenerate metadata.",
