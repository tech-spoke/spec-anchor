{"type":"item.completed","item":{"id":"item_0","type":"agent_message","text":"{\"sections\":[{\"section_id\":\"docs/spec/automation.md#0001-automation-service-spec\",\"summary\":\"\",\"search_keys\":[]},{\"section_id\":\"docs/spec/automation.md#0002-order-approval-policy\",\"summary\":\"All orders are auto-approved, including high-value orders above 1000 USD; no human approval or waiting state is ever used.\",\"search_keys\":[\"automatic order approval\",\"high-value orders\",\"manager approval not required\",\"orders above one thousand dollars\",\"no waiting for human decision\",\"instant approval\"]},{\"section_id\":\"docs/spec/automation.md#0003-refund-window\",\"summary\":\"Refunds are allowed at any time after purchase and are never denied because of elapsed time.\",\"search_keys\":[\"refunds with no deadline\",\"any time after purchase\",\"no refund window\",\"elapsed days never matter\",\"refunds always allowed\",\"no time limit for refunds\"]},{\"section_id\":\"docs/spec/checkout.md#0001-checkout-service-spec\",\"summary\":\"\",\"search_keys\":[]},{\"section_id\":\"docs/spec/checkout.md#0002-order-approval-policy\",\"summary\":\"Orders over 1000 USD require manager approval, stay pending, and must not ship until explicitly approved; automatic approval of high-value orders is prohibited.\",\"search_keys\":[\"manager approval required\",\"high-value orders\",\"pending approval state\",\"orders above one thousand dollars\",\"held until approved\",\"no automatic approval\"]},{\"section_id\":\"docs/spec/checkout.md#0003-refund-window\",\"summary\":\"Refunds are only allowed within 14 days of purchase; requests after that deadline must be rejected.\",\"search_keys\":[\"refund within fourteen days\",\"refund deadline\",\"after fourteen days rejected\",\"purchase date limit\",\"limited refund window\",\"no exceptions to deadline\"]}]}"}}
