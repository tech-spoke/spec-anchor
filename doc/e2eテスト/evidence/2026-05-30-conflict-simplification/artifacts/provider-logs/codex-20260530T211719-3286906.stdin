  "prompt": "{\"artifact_role\":\"retrieval_aid_not_evidence\",\"batch_completeness_rule\":\"Return exactly one item in output sections[] for every item in input sections[]. Use the exact section_id string from the input. Do not omit, add, rename, or merge sections. If a section is unclear, return empty summary and empty search_keys for that item but keep it in the output.\",\"instructions\":\"search_keys must be NATURAL LANGUAGE keywords for retrieval recall. Output domain concept phrases, chapter themes, synonyms, and the natural-language side of feature/state/warning names. Do NOT output code symbols, API names, function names, class names, CLI commands, CLI options (e.g. --rebuild), file paths, ALL_CAPS constants, PascalCase type names, or dotted technical names. Code symbols are tracked separately under `identifiers` and must not appear in `search_keys` (the two lists are disjoint by contract). If a phrase contains an identifier-shaped token, prefer the natural-language paraphrase (e.g. use 'config replace' instead of 'productStoreGroup.replace').\",\"limits\":{\"search_keys_enabled\":true,\"search_keys_max\":32,\"section_summary_max_chars\":480,\"summary_enabled\":true},\"return_shape\":{\"sections\":[{\"search_keys\":[\"string\"],\"section_id\":\"string\",\"summary\":\"string\"}]},\"sections\":[{\"heading_path\":[\"Automation Service Spec\"],\"identifiers\":[],\"section_id\":\"docs/spec/automation.md#0001-automation-service-spec\",\"stable_section_uid\":\"e393aaaa7a86e593\",\"text\":\"\\n\"},{\"heading_path\":[\"Automation Service Spec\",\"Order Approval Policy\"],\"identifiers\":[\"MUST\",\"USD\",\"required\"],\"section_id\":\"docs/spec/automation.md#0002-order-approval-policy\",\"stable_section_uid\":\"697186647f600ba9\",\"text\":\"\\nThe checkout service MUST automatically approve every order regardless of its\\ntotal amount. Manager approval is never required, including for orders above\\n1000 USD. No order is ever held waiting for a human decision.\\n\\n\"},{\"heading_path\":[\"Automation Service Spec\",\"Refund Window\"],\"identifiers\":[\"MUST\"],\"section_id\":\"docs/spec/automation.md#0003-refund-window\",\"stable_section_uid\":\"8be5dbc1c3f1ef2c\",\"text\":\"\\nThe checkout service MUST allow a refund at any time after purchase with no\\ndeadline. A refund request is never rejected because of the number of days that\\nhave elapsed since the purchase.\\n\"},{\"heading_path\":[\"Checkout Service Spec\"],\"identifiers\":[],\"section_id\":\"docs/spec/checkout.md#0001-checkout-service-spec\",\"stable_section_uid\":\"72a92af2dbb3190b\",\"text\":\"\\n\"},{\"heading_path\":[\"Checkout Service Spec\",\"Order Approval Policy\"],\"identifiers\":[\"MUST\",\"USD\",\"pending\"],\"section_id\":\"docs/spec/checkout.md#0002-order-approval-policy\",\"stable_section_uid\":\"428641a2371a3a02\",\"text\":\"\\nThe checkout service MUST require manager approval for every order whose total\\nis above 1000 USD. Such an order is held in a pending state and is never\\nshipped until a human manager explicitly approves it. Automatic approval of\\nhigh-value orders is forbidden.\\n\\n\"},{\"heading_path\":[\"Checkout Service Spec\",\"Refund Window\"],\"identifiers\":[\"MUST\"],\"section_id\":\"docs/spec/checkout.md#0003-refund-window\",\"stable_section_uid\":\"94154ebc62bf7b73\",\"text\":\"\\nThe checkout service MUST allow a refund only within 14 days of the original\\npurchase. After the 14-day window has elapsed, the service MUST reject the\\nrefund request. There is no exception to this deadline.\\n\"}],\"summary_search_keys_are_evidence\":false,\"task\":\"section_metadata\"}",
