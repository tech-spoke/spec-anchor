{"type":"item.completed","item":{"id":"item_0","type":"agent_message","text":"{\"sections\":[{\"section_id\":\"docs/spec/automation.md#0001-automation-service-spec\",\"summary\":\"\",\"search_keys\":[]},{\"section_id\":\"docs/spec/automation.md#0002-order-approval-policy\",\"summary\":\"Specifies that every order is auto-approved, even high-value orders above 1000 USD, with no human review or waiting state.\",\"search_keys\":[\"automatic order approval\",\"no human approval\",\"high-value orders\",\"orders above one thousand dollars\",\"never pending\",\"no waiting for manager decision\"]},{\"section_id\":\"docs/spec/automation.md#0003-refund-window\",\"summary\":\"Allows refunds at any time after purchase with no deadline or day limit, and never rejects based on elapsed time.\",\"search_keys\":[\"refunds anytime\",\"no refund deadline\",\"no time limit for refunds\",\"refund after purchase\",\"elapsed days do not matter\",\"unlimited refund window\"]},{\"section_id\":\"docs/spec/checkout.md#0001-checkout-service-spec\",\"summary\":\"\",\"search_keys\":[]},{\"section_id\":\"docs/spec/checkout.md#0002-order-approval-policy\",\"summary\":\"Requires manager approval for orders above 1000 USD, keeps them pending until explicitly approved, and forbids automatic approval of high-value orders.\",\"search_keys\":[\"manager approval required\",\"high-value orders\",\"orders above one thousand dollars\",\"pending state\",\"explicit human approval\",\"no automatic approval\"]},{\"section_id\":\"docs/spec/checkout.md#0003-refund-window\",\"summary\":\"Restricts refunds to within 14 days of purchase and rejects any refund request after that deadline.\",\"search_keys\":[\"refund within fourteen days\",\"refund deadline\",\"expired refund request\",\"purchase return window\",\"late refunds rejected\",\"two-week refund limit\"]}]}"}}
