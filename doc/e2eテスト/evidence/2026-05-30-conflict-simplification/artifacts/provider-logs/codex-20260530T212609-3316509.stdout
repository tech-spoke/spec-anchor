{"type":"item.started","item":{"id":"item_0","type":"command_execution","command":"/bin/bash -lc \"python3 - <<'PY'\nimport hashlib\ntexts=[\n'The checkout service MUST require manager approval for every order whose total is above 1000 USD.',\n'Such an order is held in a pending state and is never shipped until a human manager explicitly approves it.',\n'Automatic approval of high-value orders is forbidden.',\n'(E2E edit: clarified that this rule applies to all storefront channels.)'\n]\nfor t in texts:\n    n=' '.join(t.split())\n    print(hashlib.sha256(n.encode()).hexdigest(), n)\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
