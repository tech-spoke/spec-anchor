{"type":"item.completed","item":{"id":"item_0","type":"agent_message","text":"{\"sections\":[{\"section_id\":\"docs/spec/operations.md#0001-operations-source-spec\",\"summary\":\"\",\"search_keys\":[]},{\"section_id\":\"docs/spec/operations.md#0002-maintenance-workflow\",\"summary\":\"Describes how operators refresh extracted spec data after source documentation changes, using incremental runs for routine updates and broader refresh or rebuild modes when the source state needs to be fully recalculated.\",\"search_keys\":[\"incremental refresh after spec changes\",\"routine maintenance workflow\",\"full refresh of extracted data\",\"collection rebuild after source updates\",\"operator refresh process\",\"source spec update cycle\",\"rebuild after fixing source state\"]},{\"section_id\":\"docs/spec/operations.md#0003-agent-output-boundary\",\"summary\":\"Defines the boundary for agent-facing output: present concise constraint summaries, affected targets, related sections, discarded paths, and uncertainty, while keeping raw internal JSON as stored evidence unless explicitly requested.\",\"search_keys\":[\"agent-facing summary boundary\",\"constraint summary for users\",\"related sections and uncertainty\",\"discarded paths in output\",\"raw evidence kept internal\",\"user-facing output limits\",\"summary versus stored evidence\"]},{\"section_id\":\"docs/spec/runtime.md#0001-runtime-source-spec\",\"summary\":\"\",\"search_keys\":[]},{\"section_id\":\"docs/spec/runtime.md#0002-product-catalog-runtime\",\"summary\":\"Explains that the product catalog runtime must keep product identifiers stable across search and checkout, and that catalog updates preserve the product store identity and its migration hook.\",\"search_keys\":[\"stable product identifiers\",\"catalog updates preserve identity\",\"search and checkout consistency\",\"product catalog runtime behavior\",\"migration hook for catalog replacement\",\"preserve store identity across updates\",\"validated catalog identity\"]},{\"section_id\":\"docs/spec/runtime.md#0003-session-runtime-contract\",\"summary\":\"Describes authenticated session behavior with bearer token renewal and the session guard's handling of missing or stale authentication tokens, including recovery by rebuilding the source state after fixes.\",\"search_keys\":[\"authenticated session renewal\",\"missing authentication token\",\"stale session token handling\",\"session guard recovery\",\"bearer token refresh\",\"rebuild after fixing source state\",\"runtime session contract\"]},{\"section_id\":\"docs/spec/runtime.md#0004-checkout-integration\",\"summary\":\"States that checkout consumes validated catalog entries, and that retrieval aids and the core source-spec evidence remain the authoritative constraints for navigation and integration behavior.\",\"search_keys\":[\"checkout uses validated catalog entries\",\"retrieval aids for navigation\",\"source spec as constraint evidence\",\"core concept and purpose sections\",\"resolved conflict review items\",\"checkout integration constraints\",\"validated entries for checkout\"]}]}"}}
