{"type":"item.completed","item":{"id":"item_0","type":"agent_message","text":"{\"sections\":[{\"section_id\":\"docs/spec/operations.md#0001-operations-source-spec\",\"summary\":\"\",\"search_keys\":[]},{\"section_id\":\"docs/spec/operations.md#0002-maintenance-workflow\",\"summary\":\"Operators refresh the source-spec index after documentation changes, using incremental runs for routine updates and broader refreshes when a full rebuild is needed.\",\"search_keys\":[\"incremental index refresh\",\"full refresh after spec changes\",\"collection rebuild\",\"operator maintenance workflow\",\"source spec updates\"]},{\"section_id\":\"docs/spec/operations.md#0003-agent-output-boundary\",\"summary\":\"Agent-facing output should stay at the level of constraints, targets, related sections, discarded paths, and uncertainty, while raw internal evidence remains internal unless explicitly requested.\",\"search_keys\":[\"agent-facing summary boundary\",\"constraints and targets\",\"related sections and uncertainty\",\"discarded paths\",\"internal evidence only\"]},{\"section_id\":\"docs/spec/runtime.md#0001-runtime-source-spec\",\"summary\":\"\",\"search_keys\":[]},{\"section_id\":\"docs/spec/runtime.md#0002-product-catalog-runtime\",\"summary\":\"The product catalog keeps product identifiers stable across search and checkout, and catalog updates must preserve identity during migration or replacement flows.\",\"search_keys\":[\"product catalog stability\",\"stable product identity\",\"search and checkout consistency\",\"catalog update migration\",\"preserve identifier\"]},{\"section_id\":\"docs/spec/runtime.md#0003-session-runtime-contract\",\"summary\":\"Authenticated sessions rely on bearer token renewal, and the session guard must report missing or stale authentication tokens so operators can recover by rebuilding source state after fixes.\",\"search_keys\":[\"authenticated session renewal\",\"missing authentication token\",\"stale token warning\",\"session guard recovery\",\"rebuild after fixing source state\"]},{\"section_id\":\"docs/spec/runtime.md#0004-checkout-integration\",\"summary\":\"Checkout consumes validated catalog entries, and retrieval aids should support navigation while source specs, purpose, core concept, and resolved review items remain the authoritative constraint evidence.\",\"search_keys\":[\"checkout uses validated entries\",\"navigation support for retrieval aids\",\"authoritative constraint evidence\",\"source specs and purpose\",\"resolved review items\"]}]}"}}
