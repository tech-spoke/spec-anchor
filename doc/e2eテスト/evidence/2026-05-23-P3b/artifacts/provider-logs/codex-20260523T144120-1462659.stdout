{"type":"item.completed","item":{"id":"item_0","type":"agent_message","text":"{\"sections\":[{\"section_id\":\"docs/spec/operations.md#0001-operations-source-spec\",\"summary\":\"\",\"search_keys\":[]},{\"section_id\":\"docs/spec/operations.md#0002-maintenance-workflow\",\"summary\":\"Operators refresh retrieval data incrementally when Source Specs change, use a full refresh for broader updates, and rebuild the collection after major state changes.\",\"search_keys\":[\"incremental refresh after spec changes\",\"full refresh workflow\",\"collection rebuild\",\"maintenance after source spec updates\",\"operator refresh process\"]},{\"section_id\":\"docs/spec/operations.md#0003-agent-output-boundary\",\"summary\":\"Agent-facing output should stay concise and include constraints, targets, related sections, discarded paths, and uncertainty, while raw internal evidence remains hidden unless explicitly requested.\",\"search_keys\":[\"agent-facing summary boundary\",\"constraints and targets summary\",\"related sections and uncertainty\",\"discarded paths\",\"internal evidence not shown\"]},{\"section_id\":\"docs/spec/runtime.md#0001-runtime-source-spec\",\"summary\":\"\",\"search_keys\":[]},{\"section_id\":\"docs/spec/runtime.md#0002-product-catalog-runtime\",\"summary\":\"The product catalog must keep product identifiers stable across search and checkout, even when catalog updates are applied through migration hooks.\",\"search_keys\":[\"product catalog stability\",\"stable product identifiers\",\"search and checkout consistency\",\"catalog update migration\",\"preserve identifiers during updates\"]},{\"section_id\":\"docs/spec/runtime.md#0003-session-runtime-contract\",\"summary\":\"Authenticated sessions rely on bearer token renewal, and the session guard flags missing or stale authentication tokens so the operator can recover by rebuilding after fixing source state.\",\"search_keys\":[\"authenticated session renewal\",\"bearer token renewal\",\"missing or stale authentication token\",\"session guard warning\",\"recover after rebuilding source state\"]},{\"section_id\":\"docs/spec/runtime.md#0004-checkout-integration\",\"summary\":\"Checkout should consume validated catalog entries, with retrieval aids used for navigation and source-spec evidence retained as the basis for constraints.\",\"search_keys\":[\"checkout uses validated catalog entries\",\"navigation support for retrieval\",\"source spec evidence\",\"constraint evidence\",\"validated checkout flow\"]}]}"}}
