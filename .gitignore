# Local editor / shell state
.DS_Store
*.swp
.envrc

# Python build / cache
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/
*.egg-info/
build/
dist/

# Agent / tool local state
.codex/
.code-intel/
.playwright-mcp/

# SPEC-grag generated runtime state
.spec-grag/context/
.spec-grag/cache/
.spec-grag/graph/
.spec-grag/logs/
.spec-grag/pending/
.spec-grag/runs/
.spec-grag/state/
