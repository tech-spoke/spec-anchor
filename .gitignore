# Local editor / shell state
.DS_Store
*.swp
.envrc

# Python build / cache
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/
*.egg-info/
build/
dist/

# Agent / tool local state
.codex/
.code-intel/
.playwright-mcp/

# Packaged Agent templates are source files, not local Agent state.
!spec_grag/templates/.codex/
!spec_grag/templates/.codex/skills/
!spec_grag/templates/.codex/skills/spec-grag/
!spec_grag/templates/.codex/skills/spec-grag/SKILL.md

# SPEC-grag generated runtime state
.spec-grag.backup-before-full-suite-*/
.spec-grag.full-corpus-backup-*/
.spec-grag.pytest-stash-*/
.spec-grag/context/
.spec-grag/cache/
.spec-grag/graph/
.spec-grag/logs/
.spec-grag/pending/
.spec-grag/runs/
.spec-grag/state/
.spec-grag/tmp/

# Claude Code runtime locks
.claude/scheduled_tasks.lock

# Archived local runtime state. Source/docs under archive stay visible to Git.
archive/**/.envrc
archive/**/.venv/
archive/**/.codex/
archive/**/.code-intel/
archive/**/.pytest_cache/
archive/**/.playwright-mcp/
archive/**/*.egg-info/
archive/**/__pycache__/
archive/**/spike_storage/
archive/**/.spec-grag/cache/
archive/**/.spec-grag/graph/
archive/**/.spec-grag/logs/
archive/**/.spec-grag/pending/
archive/**/.spec-grag/runs/
archive/**/.spec-grag/state/
archive/**/.spec-grag/tmp/
