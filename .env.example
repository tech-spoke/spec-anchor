# spec-grag project-local environment variable overrides.
# Copy to .env (gitignored) and uncomment / set values to enable.

# When set to a truthy value (1 / true / yes / on), spec-grag core uses the
# in-process FakeLlmProvider regardless of [llm.providers.<id>] contents.
# Used for tests / smoke runs that must not spawn real codex / claude CLIs.
# SPEC_GRAG_FAKE_PROVIDER=1

# Provider id to use for spec-grag core (overrides [llm.stage_routing] and
# applies the same provider to every stage). Equivalent to CLI --llm-provider.
# SPEC_GRAG_LLM_PROVIDER=codex

# Qdrant URL override (smoke / setup probe).
# SPEC_GRAG_QDRANT_URL=http://localhost:6333

# Test / CI gates: enable real LLM CLI / real retrieval test paths.
# Normally set by CI pipelines, not by local .env.
# SPEC_GRAG_REAL_PROVIDER=1
# SPEC_GRAG_REAL_SMOKE=1
# SPEC_GRAG_REAL_RETRIEVAL=1
