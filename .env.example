# spec-anchor project-local environment variable overrides.
# Copy to .env (gitignored) and uncomment values to enable.
#
# Default operation is production / real mode: real codex / claude CLIs are
# spawned and real Qdrant + FlagEmbedding back the retrieval. Each variable
# below switches one subsystem to its in-process fake implementation.

# When truthy (1 / true / yes / on), spec-anchor core skips spawning the
# configured CLI subprocess and uses the in-process FakeLlmProvider.
# Used for tests / smoke runs that must not spawn real codex / claude CLIs.
# SPEC_ANCHOR_FAKE_LLM=1

# When truthy, FlagEmbeddingBgeM3Provider direct construction is blocked
# (unless allow_real_provider=True is passed). Use for offline / fast tests
# that should not download BGE-M3 weights or call Qdrant.
# SPEC_ANCHOR_FAKE_RETRIEVAL=1

# Qdrant URL override consumed by spec-anchor-setup-project / setup-system
# probes BEFORE .spec-anchor/config.toml is finalized. Once config exists,
# [vector_store].url is authoritative.
# SPEC_ANCHOR_QDRANT_URL=http://localhost:6333
